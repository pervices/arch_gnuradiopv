#########################################################################################################
# OBS Build Configuration.
#
# OBS does not resolve dependencies the same as Pacman usually does, so if there are multiple 
# possible sources for a package the build will fail unless the preferred package is specified.
#
# Specifying these in an OBS _config file instead of the PKGBUILD since it's OBS-specific and to keep
# the PKGBUILD as close to upstream as possible.
#########################################################################################################

# Multiple dependencies require lapack, blas, or cblas. lapack is a split package which contains blas and cblas
# so just installing lapack should be enough to satisfy any of those requirements.
Prefer: lapack
# Prefer bubblewrap over bubblewrap-suid since bubblewrap-suid is needed for linux-hardened users. See https://wiki.archlinux.org/title/Bubblewrap#Installation
Prefer: bubblewrap

# This is an OBS-specific build dependency. OBS uses obscpio archives instead of tars or directories when cloning the repo.
# cpio must be installed or the build will fail trying to extract the archives.
Required: cpio